# 环境变量配置 - 复制此文件为 .env 并填入真实配置
PORT=3000
NODE_ENV=development

# JWT密钥（生产环境请改为复杂随机字符串）
JWT_SECRET=zhuojian_secret_change_me

# 短信服务（阿里云）
ALI_KEY=your_aliyun_access_key_id
ALI_SECRET=your_aliyun_access_key_secret
ALI_SMS_SIGN=卓见心理
ALI_SMS_TEMPLATE=SMS_XXXXXX

# 邮件服务（QQ邮箱或其他SMTP）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_email_auth_code

# 微信小程序
WX_APPID=your_wechat_appid
WX_SECRET=your_wechat_app_secret

# QQ互联
QQ_APPID=your_qq_appid
QQ_SECRET=your_qq_app_secret

# 微信支付
WECHAT_PAY_MCH_ID=your_mchid
WECHAT_PAY_API_V3_KEY=your_v3_api_key
# certs/ 目录下放：apiclient_key.pem（商户私钥）、pub_key.pem（平台公钥）

# 支付宝（WAP 手机网站支付）
ALIPAY_APP_ID=your_alipay_app_id
# RSA2 应用私钥（去掉 PEM 头尾，单行或保留换行均可）
ALIPAY_APP_PRIVATE_KEY=MIIEowIBAAKCAQEA...
# 支付宝公钥（从开放平台复制）
ALIPAY_PUBLIC_KEY=MIIBIjANBgkqhkiG...
# 正式环境无需改，沙箱改为 https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# 支付完成后跳回的前端页面（H5 域名）
ALIPAY_RETURN_URL=https://yourdomain.com/pages/payment/result

# 支付回调通知地址的域名前缀（必须是公网可访问的 HTTPS 地址）
PAY_NOTIFY_BASE=https://yourdomain.com
