model Order {
  id          Int      @id @default(autoincrement())
  orderNo     String   @unique @map("order_no")       // 商户订单号
  userId      Int      @map("user_id")
  bookingId   Int?     @map("booking_id")
  amount      Int                                      // 单位：分
  status      String   @default("pending")             // pending / paid / cancelled / refunded
  payType     String   @default("wxpay") @map("pay_type")
  prepayId    String?  @map("prepay_id")               // 微信预支付ID
  transactionId String? @map("transaction_id")         // 微信支付交易号
  expireAt    DateTime @map("expire_at")               // 15分钟未支付自动过期
  paidAt      DateTime? @map("paid_at")
  originalAmount Int?     @map("original_amount")              // 折扣前原价（分），无折扣时为 null
  discountRate   Float    @default(1.0) @map("discount_rate")  // 下单时折扣快照
  userPackageId  Int?     @map("user_package_id")              // 套餐购买订单关联
  userCouponId   Int?     @map("user_coupon_id")               // 使用的优惠券
  couponDiscount Int      @default(0) @map("coupon_discount")  // 优惠券减免金额（分）
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id])
  booking     Booking? @relation(fields: [bookingId], references: [id])
  userPackage UserPackage? @relation(fields: [userPackageId], references: [id])
  userCoupon  UserCoupon?  @relation(fields: [userCouponId], references: [id])
  @@map("orders")
}

// ── 套餐定义（admin 配置）────────────────────────────────────────
model ConsultPackage {
  id             Int           @id @default(autoincrement())
  name           String                                        // 套餐名称，如"十次套餐"
  sessions       Int                                           // 购买次数（如 10）
  bonusSessions  Int           @default(0) @map("bonus_sessions") // 赠送次数（如 1）
  description    String?                                       // 套餐说明
  isActive       Int           @default(1) @map("is_active")
  sortOrder      Int           @default(0) @map("sort_order")
  createdAt      DateTime      @default(now()) @map("created_at")
  userPackages   UserPackage[]
  @@map("consult_packages")
}

// ── 用户持有的套餐 ──────────────────────────────────────────────
model UserPackage {
  id             Int            @id @default(autoincrement())
  userId         Int            @map("user_id")
  packageId      Int            @map("package_id")
  totalSessions  Int            @map("total_sessions")         // 购买+赠送总次数
  usedSessions   Int            @default(0) @map("used_sessions")
  paidAmount     Int            @map("paid_amount")            // 实付金额（分）
  status         String         @default("active")             // active / exhausted / expired
  expireAt       DateTime?      @map("expire_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  user           User           @relation(fields: [userId], references: [id])
  package        ConsultPackage @relation(fields: [packageId], references: [id])
  orders         Order[]
  @@map("user_packages")
}

// ── 优惠券模板（admin 配置）────────────────────────────────────
model Coupon {
  id           Int         @id @default(autoincrement())
  code         String      @unique                          // 券码/活动码，WELCOME_DISCOUNT 等
  name         String                                       // 展示名称，如"注册8折券"
  description  String?                                      // 使用说明
  type         String                                       // 'discount'|'threshold'|'direct'|'activity'
  value        Float                                        // 打折:0.8；满减/直减:减免金额(分)；活动:0
  threshold    Int         @default(0)                      // 满减门槛(分)，0=无门槛
  scope        String      @default("consultation")         // 'consultation'|'salon'|'all'
  isPublic     Int         @default(0) @map("is_public")   // 1=活动券用户可见/自领
  perUserLimit Int         @default(1) @map("per_user_limit") // 每人可持有次数
  totalLimit   Int?        @map("total_limit")              // 发行总量(null=不限)
  usedCount    Int         @default(0) @map("used_count")
  expireAt     DateTime?   @map("expire_at")                // null=永久有效
  isActive     Int         @default(1) @map("is_active")
  createdBy    Int         @map("created_by")               // admin userId
  createdAt    DateTime    @default(now()) @map("created_at")
  userCoupons  UserCoupon[]
  @@map("coupons")
}

// ── 用户持有的优惠券（每张用完即消）──────────────────────────
model UserCoupon {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  couponId    Int       @map("coupon_id")
  status      String    @default("available")   // 'available'|'used'|'expired'
  usedAt      DateTime? @map("used_at")
  usedOrderId Int?      @map("used_order_id")   // 用于哪个订单
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id])
  coupon      Coupon    @relation(fields: [couponId], references: [id])
  orders      Order[]
  @@map("user_coupons")
}

model MoodEntry {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  mood      Int
  note      String?
  tags      String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("mood_entries")
}

model CbtRecord {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  situation       String
  autoThought     String   @map("auto_thought")
  emotion         String
  evidenceFor     String?  @map("evidence_for")
  evidenceAgainst String?  @map("evidence_against")
  balancedThought String?  @map("balanced_thought")
  outcome         String?
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  @@map("cbt_records")
}

model DreamRecord {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  dreamContent    String   @map("dream_content")
  freeAssociation String?  @map("free_association")
  interpretation  String?
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  @@map("dream_records")
}

model IcebergRecord {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  behavior          String
  coping            String?
  feeling           String?
  feelingOfFeeling  String?  @map("feeling_of_feeling")
  belief            String?
  expectation       String?
  yearning          String?
  self              String?
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  @@map("iceberg_records")
}

model HomeworkHelp {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  consultantId Int?     @map("consultant_id")
  recordType   String   @map("record_type")
  recordId     Int      @map("record_id")
  status       String   @default("pending")
  reply        String?
  price        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  @@map("homework_help")
}

model RuleRecord {
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  originalRule     String   @map("original_rule")
  context          String?
  source           String?
  originalFunction String?  @map("original_function")
  cost             String?
  exceptions       String?
  newRule          String?  @map("new_rule")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  @@map("rule_records")
}
